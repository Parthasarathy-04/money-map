{"ast":null,"code":"import{useState,useEffect}from'react';export const useCurrency=()=>{const[currency,setCurrency]=useState(localStorage.getItem('currency')||'৳');useEffect(()=>{localStorage.setItem('currency',currency);},[currency]);const changeCurrency=newCurrency=>{setCurrency(newCurrency);};return{currency,changeCurrency};};","map":{"version":3,"names":["useState","useEffect","useCurrency","currency","setCurrency","localStorage","getItem","setItem","changeCurrency","newCurrency"],"sources":["C:/Users/jkpar/OneDrive/Desktop/Moneymap-app/frontend/src/components/theme/useCurrency.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport const useCurrency = () => {\n  const [currency, setCurrency] = useState(localStorage.getItem('currency') || '৳');\n\n  useEffect(() => {\n    localStorage.setItem('currency', currency);\n  }, [currency]);\n\n  const changeCurrency = (newCurrency) => {\n    setCurrency(newCurrency);\n  };\n\n  return { currency, changeCurrency };\n};"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,MAAM,CAAAC,WAAW,CAAGA,CAAA,GAAM,CAC/B,KAAM,CAACC,QAAQ,CAAEC,WAAW,CAAC,CAAGJ,QAAQ,CAACK,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC,EAAI,GAAG,CAAC,CAEjFL,SAAS,CAAC,IAAM,CACdI,YAAY,CAACE,OAAO,CAAC,UAAU,CAAEJ,QAAQ,CAAC,CAC5C,CAAC,CAAE,CAACA,QAAQ,CAAC,CAAC,CAEd,KAAM,CAAAK,cAAc,CAAIC,WAAW,EAAK,CACtCL,WAAW,CAACK,WAAW,CAAC,CAC1B,CAAC,CAED,MAAO,CAAEN,QAAQ,CAAEK,cAAe,CAAC,CACrC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}